#!/usr/bin/env bash
#
# pre-commit hook — runs phpcs on the plugin file.
# Install: composer install  (post-install-cmd copies this file automatically)
# Manual:  cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#
# WARN-ONLY mode: exits 0 so commits are never blocked by pre-existing WPCS
# violations. The full compliance pass is a tracked backlog task. Change
# EXIT_CODE to 1 once the codebase is clean to enforce strict blocking.

PHPCS="dev-vendor/bin/phpcs"
PLUGIN="rankmath-rest-bridge.php"
EXIT_CODE=0  # set to 1 to enforce blocking after WPCS compliance pass

if [ ! -f "$PHPCS" ]; then
    echo "[pre-commit] phpcs not found. Run 'composer install' to enable lint checks."
    exit 0
fi

echo "[pre-commit] Linting $PLUGIN (warn-only until WPCS compliance pass is complete)..."
if ! "$PHPCS" --standard=phpcs.xml.dist "$PLUGIN"; then
    echo ""
    echo "[pre-commit] Lint issues found. Run 'composer run lint-fix' to auto-fix where possible."
    echo "[pre-commit] Full compliance pass is tracked in projectStatus.md backlog."
    exit $EXIT_CODE
fi

echo "[pre-commit] Lint passed."
