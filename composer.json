{
  "name": "rankrocket/seo-control-layer",
  "description": "RankRocket SEO Control Layer - WordPress plugin",
  "type": "wordpress-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.9",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^9.6",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "config": {
    "vendor-dir": "dev-vendor",
    "platform": {
      "php": "7.4.33"
    },
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "post-install-cmd": [
      "php -r \"@copy('hooks/pre-commit', '.git/hooks/pre-commit'); @chmod('.git/hooks/pre-commit', 0755); echo 'pre-commit hook installed.\\n';\"",
      "php -r \"@copy('hooks/pre-push',   '.git/hooks/pre-push');   @chmod('.git/hooks/pre-push',   0755); echo 'pre-push hook installed.\\n';\""
    ],
    "post-update-cmd": [
      "php -r \"@copy('hooks/pre-commit', '.git/hooks/pre-commit'); @chmod('.git/hooks/pre-commit', 0755); echo 'pre-commit hook updated.\\n';\"",
      "php -r \"@copy('hooks/pre-push',   '.git/hooks/pre-push');   @chmod('.git/hooks/pre-push',   0755); echo 'pre-push hook updated.\\n';\""
    ],
    "lint":     "phpcs --standard=phpcs.xml.dist rankmath-rest-bridge.php",
    "lint-fix": "phpcbf --standard=phpcs.xml.dist rankmath-rest-bridge.php",
    "test":     "phpunit --configuration phpunit.xml.dist",
    "qa":       ["@lint", "@test"]
  }
}
